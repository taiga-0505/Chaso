{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🚀 Run Debug (ビルド＆実行)",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy", "Bypass", "-File", "scripts/build/build_and_run.ps1", "-Configuration", "Debug"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        },
        {
